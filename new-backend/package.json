{
  "name": "civicguide-backend",
  "version": "1.0.0",
  "description": "CivicGuide AI Supersystem — Hardened Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js"
  },
  "nodemonConfig": {
    "ignore": [
      "uploads/*",
      "logs/*",
      "*.log",
      "node_modules/*"
    ],
    "watch": [
      "src/",
      "server.js"
    ],
    "ext": "js,json"
  },
  "dependencies": {
    "@google-cloud/aiplatform": "^3.0.0",
    "@google-cloud/language": "^6.2.0",
    "@google-cloud/logging-winston": "^6.0.0",
    "@google-cloud/pubsub": "^4.0.0",
    "@google-cloud/speech": "^6.3.0",
    "@google-cloud/storage": "^7.0.0",
    "@google-cloud/text-to-speech": "^5.3.0",
    "@google-cloud/translate": "^8.2.0",
    "@google/generative-ai": "^0.24.1",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.2.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "mongoose": "^8.3.0",
    "morgan": "^1.10.0",
    "rate-limit-redis": "^4.2.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.8",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  }
}
